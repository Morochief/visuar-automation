# =============================================================
# Environment Variables Configuration
# Copy this file to .env and fill in your values
# =============================================================

# AI Product Matching (DeepSeek via NVIDIA)
# Get your API key from: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# Security (PostgreSQL pgcrypto encryption)
# Use a strong 32+ character key for production
ENCRYPTION_KEY=your_secure_encryption_key_here

# Flask environment (set to 'production' for production deployments)
FLASK_ENV=development

# Optional: Frontend port
# FRONTEND_PORT=4321
